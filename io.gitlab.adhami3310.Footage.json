{
    "id": "io.gitlab.adhami3310.Footage",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/lib/girepository-1.0",
        "/libexec",
        "/man",
        "/share/aclocal",
        "/share/gir-1.0",
        "/share/man",
        "*.la",
        "*.a"
    ],
    "command": "footage",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland",
        "--socket=pulseaudio"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin"
    },
    "modules": [
        {
            "name": "gstreamer-editing-services",
            "buildsystem": "meson",
            "config-opts": [
                "-Ddoc=disabled",
                "-Dexamples=disabled",
                "-Dintrospection=disabled",
                "-Dtests=disabled",
                "-Dtools=disabled",
                "-Dbash-completion=disabled",
                "-Dpython=disabled"
            ],
            "subdir": "subprojects/gst-editing-services",
            "sources": [
                {
                    "type": "git",
                    "tag": "1.26.10",
                    "url": "https://gitlab.freedesktop.org/gstreamer/gstreamer.git",
                    "commit": "bfdc62185e243d3633aa916187a566d03a587792",
                    "disable-submodules": true
                }
            ]
        },
        {
            "name": "x265-dev",
            "buildsystem": "simple",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://bitbucket.org/multicoreware/x265_git/downloads/x265_4.1.tar.gz",
                    "sha256": "a31699c6a89806b74b0151e5e6a7df65de4b49050482fe5ebf8a4379d7af8f29"
                },
                {
                    "type": "file",
                    "path": "x265.pc"
                }
            ],
            "build-commands": [
                "install -Dm644 source/x265.h /app/include/x265.h",
                "install -Dm644 x265.pc /app/lib/pkgconfig/x265.pc",
                "N=$(basename /usr/lib/*/codecs-extra/lib/libx265.so.* | sed 's/.*\\.so\\.//') && printf '#define X265_VERSION \"%s\"\\n#define X265_BUILD %s\\n#define X265_DEPTH 8\\n' \"$N\" \"$N\" > /app/include/x265_config.h && ln -sf /usr/lib/*/codecs-extra/lib/libx265.so /app/lib/libx265.so && ln -sf /usr/lib/*/codecs-extra/lib/libx265.so.$N /app/lib/libx265.so.$N"
            ]
        },
        {
            "name": "gstreamer-plugins-bad",
            "buildsystem": "meson",
            "config-opts": [
                "-Dauto_features=disabled",
                "-Dx265=enabled",
                "-Dgpl=enabled"
            ],
            "subdir": "subprojects/gst-plugins-bad",
            "sources": [
                {
                    "type": "git",
                    "tag": "1.26.10",
                    "url": "https://gitlab.freedesktop.org/gstreamer/gstreamer.git",
                    "commit": "bfdc62185e243d3633aa916187a566d03a587792",
                    "disable-submodules": true
                }
            ]
        },
        {
            "name": "footage",
            "builddir": true,
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://gitlab.com/-/project/46658491/uploads/82e4d7004c24cd04978dc1ed4d873cca/footage-1.4.0.tar.xz",
                    "sha256": "c9d020ac1ba1d606c0e597b75e813ea9bbaf43fe2de8131b187937b8bf4df6bf"
                }
            ]
        }
    ]
}