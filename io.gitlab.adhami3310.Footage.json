{
    "id": "io.gitlab.adhami3310.Footage",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/lib/girepository-1.0",
        "/libexec",
        "/man",
        "/share/aclocal",
        "/share/gir-1.0",
        "/share/man",
        "*.la",
        "*.a"
    ],
    "command": "footage",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland",
        "--socket=pulseaudio"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin"
    },
    "modules": [
        {
            "name": "gstreamer-editing-services",
            "buildsystem": "meson",
            "config-opts": [
                "-Ddoc=disabled",
                "-Dexamples=disabled",
                "-Dintrospection=disabled",
                "-Dtests=disabled",
                "-Dtools=disabled",
                "-Dbash-completion=disabled",
                "-Dpython=disabled"
            ],
            "subdir": "subprojects/gst-editing-services",
            "sources": [
                {
                    "type": "git",
                    "disable-submodules": true,
                    "url": "https://gitlab.freedesktop.org/gstreamer/gstreamer.git",
                    "tag": "1.26.10",
                    "commit": "bfdc62185e243d3633aa916187a566d03a587792"
                }
            ]
        },
        {
            "name": "footage",
            "builddir": true,
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://gitlab.com/-/project/46658491/uploads/7de55e281b324b13e83203a83ea1759a/footage-1.3.3.tar.xz",
                    "sha256": "aa0ac8d01e8c5cbb21a56d88029fbe641ffde478597a5d2d8adb397a90d71e80"
                }
            ]
        }
    ]
}
